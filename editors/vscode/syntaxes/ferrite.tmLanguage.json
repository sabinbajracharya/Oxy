{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Ferrite",
    "scopeName": "source.ferrite",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#attributes" },
        { "include": "#keywords" },
        { "include": "#control" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#functions" },
        { "include": "#macros" },
        { "include": "#operators" },
        { "include": "#numbers" },
        { "include": "#variables" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.ferrite",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.ferrite",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        { "include": "#comments" }
                    ]
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.ferrite",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.ferrite",
                            "match": "\\\\(n|r|t|\\\\|\"|0|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})"
                        },
                        {
                            "name": "variable.other.placeholder.ferrite",
                            "match": "\\{(:[^}]*)?\\}"
                        }
                    ]
                }
            ]
        },
        "chars": {
            "patterns": [
                {
                    "name": "string.quoted.single.ferrite",
                    "match": "'(\\\\(n|r|t|\\\\|'|0|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})|[^'\\\\])'"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.ferrite",
                    "match": "#\\[([^\\]]*)\\]",
                    "captures": {
                        "1": { "name": "entity.other.attribute-name.ferrite" }
                    }
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.other.ferrite",
                    "match": "\\b(let|mut|fn|struct|enum|impl|trait|mod|use|pub|const|static|type|as|ref|where|move|async|await|dyn|unsafe|extern|crate|super)\\b"
                },
                {
                    "name": "storage.type.ferrite",
                    "match": "\\b(let|mut|const|static)\\b"
                },
                {
                    "name": "keyword.other.fn.ferrite",
                    "match": "\\b(fn|async\\s+fn)\\b"
                }
            ]
        },
        "control": {
            "patterns": [
                {
                    "name": "keyword.control.ferrite",
                    "match": "\\b(if|else|while|loop|for|in|match|return|break|continue|spawn|sleep)\\b"
                },
                {
                    "name": "keyword.control.import.ferrite",
                    "match": "\\b(use|mod|pub|crate|super|self)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.ferrite",
                    "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char|str)\\b"
                },
                {
                    "name": "support.type.ferrite",
                    "match": "\\b(String|Vec|HashMap|Option|Result|Box|Self)\\b"
                },
                {
                    "name": "entity.name.type.ferrite",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.ferrite",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.option.ferrite",
                    "match": "\\b(None|Some|Ok|Err)\\b"
                },
                {
                    "name": "variable.language.self.ferrite",
                    "match": "\\bself\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "comment": "Function definition",
                    "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.other.fn.ferrite" },
                        "2": { "name": "entity.name.function.ferrite" }
                    }
                },
                {
                    "comment": "Function/method call",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.call.ferrite" }
                    }
                },
                {
                    "comment": "Method call after dot",
                    "match": "\\.([a-z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.method.ferrite" }
                    }
                }
            ]
        },
        "macros": {
            "patterns": [
                {
                    "name": "entity.name.function.macro.ferrite",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*!",
                    "captures": {
                        "1": { "name": "entity.name.function.macro.ferrite" }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.ferrite",
                    "match": "->|=>"
                },
                {
                    "name": "keyword.operator.path.ferrite",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.range.ferrite",
                    "match": "\\.\\.\\.|\\.\\."
                },
                {
                    "name": "keyword.operator.comparison.ferrite",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.ferrite",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.assignment.ferrite",
                    "match": "\\+=|-=|\\*=|/=|%=|="
                },
                {
                    "name": "keyword.operator.arithmetic.ferrite",
                    "match": "\\+|-|\\*|/|%"
                },
                {
                    "name": "keyword.operator.bitwise.ferrite",
                    "match": "<<|>>|&|\\||\\^"
                },
                {
                    "name": "keyword.operator.question.ferrite",
                    "match": "\\?"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.ferrite",
                    "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9_]+)?(f32|f64)?\\b"
                },
                {
                    "name": "constant.numeric.hex.ferrite",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.ferrite",
                    "match": "\\b0o[0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.ferrite",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.integer.ferrite",
                    "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.ferrite",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.semi.ferrite",
                    "match": ";"
                },
                {
                    "name": "punctuation.comma.ferrite",
                    "match": ","
                },
                {
                    "name": "punctuation.dot.ferrite",
                    "match": "\\."
                }
            ]
        }
    }
}
