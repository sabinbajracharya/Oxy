{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Oxy",
    "scopeName": "source.oxy",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#attributes" },
        { "include": "#keywords" },
        { "include": "#control" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#functions" },
        { "include": "#macros" },
        { "include": "#operators" },
        { "include": "#numbers" },
        { "include": "#variables" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.oxy",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.oxy",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        { "include": "#comments" }
                    ]
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.oxy",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.oxy",
                            "match": "\\\\(n|r|t|\\\\|\"|0|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})"
                        },
                        {
                            "name": "variable.other.placeholder.oxy",
                            "match": "\\{(:[^}]*)?\\}"
                        }
                    ]
                }
            ]
        },
        "chars": {
            "patterns": [
                {
                    "name": "string.quoted.single.oxy",
                    "match": "'(\\\\(n|r|t|\\\\|'|0|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})|[^'\\\\])'"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.oxy",
                    "match": "#\\[([^\\]]*)\\]",
                    "captures": {
                        "1": { "name": "entity.other.attribute-name.oxy" }
                    }
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.other.oxy",
                    "match": "\\b(val|var|let|mut|fn|struct|enum|impl|trait|mod|use|pub|const|static|type|as|ref|where|move|async|await|dyn|unsafe|extern|crate|super)\\b"
                },
                {
                    "name": "storage.type.oxy",
                    "match": "\\b(val|var|const|static)\\b"
                },
                {
                    "name": "keyword.other.fn.oxy",
                    "match": "\\b(fn|async\\s+fn)\\b"
                }
            ]
        },
        "control": {
            "patterns": [
                {
                    "name": "keyword.control.oxy",
                    "match": "\\b(if|else|while|loop|for|in|match|return|break|continue)\\b"
                },
                {
                    "name": "keyword.control.import.oxy",
                    "match": "\\b(use|mod|pub|crate|super|self)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.oxy",
                    "match": "\\b(int|byte|float|bool|char|str)\\b"
                },
                {
                    "name": "support.type.oxy",
                    "match": "\\b(String|Vec|HashMap|Option|Result|Box|Self)\\b"
                },
                {
                    "name": "entity.name.type.oxy",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.oxy",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.option.oxy",
                    "match": "\\b(None|Some|Ok|Err)\\b"
                },
                {
                    "name": "variable.language.self.oxy",
                    "match": "\\bself\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "comment": "Function definition",
                    "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.other.fn.oxy" },
                        "2": { "name": "entity.name.function.oxy" }
                    }
                },
                {
                    "comment": "Function/method call",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.call.oxy" }
                    }
                },
                {
                    "comment": "Method call after dot",
                    "match": "\\.([a-z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.method.oxy" }
                    }
                }
            ]
        },
        "macros": {
            "patterns": [
                {
                    "name": "entity.name.function.macro.oxy",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*!",
                    "captures": {
                        "1": { "name": "entity.name.function.macro.oxy" }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.oxy",
                    "match": "->|=>"
                },
                {
                    "name": "keyword.operator.path.oxy",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.range.oxy",
                    "match": "\\.\\.\\.|\\.\\."
                },
                {
                    "name": "keyword.operator.comparison.oxy",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.oxy",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.assignment.oxy",
                    "match": "\\+=|-=|\\*=|/=|%=|="
                },
                {
                    "name": "keyword.operator.arithmetic.oxy",
                    "match": "\\+|-|\\*|/|%"
                },
                {
                    "name": "keyword.operator.bitwise.oxy",
                    "match": "<<|>>|&|\\||\\^"
                },
                {
                    "name": "keyword.operator.question.oxy",
                    "match": "\\?"
                },
                {
                    "name": "keyword.operator.cascade.oxy",
                    "match": "~>"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.oxy",
                    "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.hex.oxy",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.oxy",
                    "match": "\\b0o[0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.oxy",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.integer.oxy",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.oxy",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.semi.oxy",
                    "match": ";"
                },
                {
                    "name": "punctuation.comma.oxy",
                    "match": ","
                },
                {
                    "name": "punctuation.dot.oxy",
                    "match": "\\."
                }
            ]
        }
    }
}
