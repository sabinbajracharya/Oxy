{
    "name": "oxy-lang",
    "displayName": "Oxy Language",
    "description": "Syntax highlighting and LSP support for the Oxy programming language (.ox files)",
    "version": "0.1.0",
    "publisher": "oxy-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/nickel-lang/project-ferrite"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:oxy"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "oxy",
                "aliases": [
                    "Oxy",
                    "oxy"
                ],
                "extensions": [
                    ".ox"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "oxy",
                "scopeName": "source.oxy",
                "path": "./syntaxes/oxy.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Oxy",
            "properties": {
                "oxy.lsp.path": {
                    "type": "string",
                    "default": "oxy-lsp",
                    "description": "Path to the oxy-lsp binary. Only used when mode is 'native'."
                },
                "oxy.lsp.mode": {
                    "type": "string",
                    "default": "auto",
                    "enum": [
                        "auto",
                        "docker",
                        "native"
                    ],
                    "enumDescriptions": [
                        "Auto-detect: uses Docker if no custom path is set, native binary otherwise",
                        "Always launch LSP via Docker (no local Rust needed)",
                        "Use a local oxy-lsp binary directly"
                    ],
                    "description": "How to launch the Oxide Language Server."
                },
                "oxy.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable the Oxide Language Server for diagnostics, completion, hover, and go-to-definition."
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@vscode/vsce": "^2.24.0"
    },
    "scripts": {
        "package": "vsce package --no-dependencies",
        "install-ext": "code --install-extension oxy-lang-*.vsix"
    }
}
