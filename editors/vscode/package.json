{
    "name": "ferrite-lang",
    "displayName": "Ferrite Language",
    "description": "Syntax highlighting and LSP support for the Ferrite programming language (.fe files)",
    "version": "0.1.0",
    "publisher": "ferrite-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/nickel-lang/project-ferrite"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:ferrite"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "ferrite",
                "aliases": [
                    "Ferrite",
                    "ferrite"
                ],
                "extensions": [
                    ".fe"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ferrite",
                "scopeName": "source.ferrite",
                "path": "./syntaxes/ferrite.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Ferrite",
            "properties": {
                "ferrite.lsp.path": {
                    "type": "string",
                    "default": "ferrite-lsp",
                    "description": "Path to the ferrite-lsp binary. Only used when mode is 'native'."
                },
                "ferrite.lsp.mode": {
                    "type": "string",
                    "default": "auto",
                    "enum": [
                        "auto",
                        "docker",
                        "native"
                    ],
                    "enumDescriptions": [
                        "Auto-detect: uses Docker if no custom path is set, native binary otherwise",
                        "Always launch LSP via Docker (no local Rust needed)",
                        "Use a local ferrite-lsp binary directly"
                    ],
                    "description": "How to launch the Ferrite Language Server."
                },
                "ferrite.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable the Ferrite Language Server for diagnostics, completion, hover, and go-to-definition."
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@vscode/vsce": "^2.24.0"
    },
    "scripts": {
        "package": "vsce package --no-dependencies",
        "install-ext": "code --install-extension ferrite-lang-*.vsix"
    }
}
