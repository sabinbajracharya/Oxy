// arithmetic.ox — Basic arithmetic operations
fn main() {
    val a = 10;
    val b = 3;

    println("{} + {} = {}", a, b, a + b);
    println("{} - {} = {}", a, b, a - b);
    println("{} * {} = {}", a, b, a * b);
    println("{} / {} = {}", a, b, a / b);
    println("{} % {} = {}", a, b, a % b);

    val x = 2.5;
    val y = 1.5;
    println("{} + {} = {}", x, y, x + y);
}
